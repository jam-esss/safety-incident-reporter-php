{
  "name": "jam-esss/safety-incident-reporter-php",
  "description": "Safety incident reporter PHP.",
  "type": "project",
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "app/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "Tests/"
    }
  },
  "require": {
    "ext-pdo": "*",
    "ext-json": "*",
    "ext-ftp": "*",
    "ext-gd": "*",
    "ext-curl": "*",
    "league/route": "^6.2",
    "league/plates": "^3.6",
    "laminas/laminas-diactoros": "^3.8",
    "laminas/laminas-httphandlerrunner": "^2.13",
    "vlucas/phpdotenv": "^5.6",
    "ext-http": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^1.10",
    "roave/security-advisories": "dev-master"
  },
  "scripts": {
    "test": "phpunit --colors=always",
    "cs:fix": "php-cs-fixer fix",
    "analyse": "phpstan analyse src tests --level=max"
  }
}
